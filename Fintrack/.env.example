ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SECRET_KEY=
DATABASE_URL=

# ── PostHog product analytics (server-side capture only) ──
# POSTHOG_API_KEY: project key from posthog.com (EU region recommended).
#   Without this set, app/services/analytics_service.py runs in no-op
#   mode — events are dropped, no errors raised.
# POSTHOG_HOST: defaults to https://eu.i.posthog.com when blank.
#   Override only if you self-host PostHog or use a different region.
# In production, set these in the Render dashboard environment variables;
# otherwise events fail silently in prod.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
