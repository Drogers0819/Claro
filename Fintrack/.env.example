ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SECRET_KEY=
DATABASE_URL=

# ── PostHog product analytics (server-side capture only) ──
# POSTHOG_API_KEY: project key from posthog.com (EU region recommended).
#   Without this set, app/services/analytics_service.py runs in no-op
#   mode — events are dropped, no errors raised.
# POSTHOG_HOST: defaults to https://eu.i.posthog.com when blank.
#   Override only if you self-host PostHog or use a different region.
# In production, set these in the Render dashboard environment variables;
# otherwise events fail silently in prod.
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ── Sentry error monitoring (errors only) ──
# All three are OPTIONAL in local dev — leave blank and Sentry no-ops,
# nothing breaks. Set SENTRY_DSN in the Render dashboard for production.
# SENTRY_DSN: the project DSN from sentry.io (Settings → Projects →
#   [project] → Client Keys (DSN)). When blank, error monitoring is
#   disabled entirely (see app/observability.py).
# SENTRY_ENVIRONMENT: tags events so staging vs production is
#   distinguishable in the dashboard. Defaults to "production" when unset.
# SENTRY_DEBUG_ENABLED: set to 1 ONLY temporarily to expose the
#   /debug/sentry-test verification route. Leave unset/blank normally —
#   when unset that route returns 404. Remove after verifying Sentry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_DEBUG_ENABLED=
